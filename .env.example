# Database (Prisma 7 + PostgreSQL / Neon)
# DATABASE_URL = pooled connection (runtime, used by the pg driver adapter)
# DIRECT_URL   = direct/unpooled connection (migrations: prisma migrate deploy)
DATABASE_URL="postgresql://user:password@host:5432/shelfie?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/shelfie?sslmode=require"

# Secret for signing session JWTs (jose, HS256). MUST be set on Vercel.
# Generate a strong value, e.g.: openssl rand -base64 32
SESSION_SECRET="change-me-in-production"
